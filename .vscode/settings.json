{
  "search.exclude": {
    "**/node_modules": true,
    "**/bower_components": true,
    "**/.sf": true,
    "**/.sfdx": true
  },
  "files.exclude": {
    "**/.apivcs": true,
    "**/.gitignore": true,
    "**/.git": true,
    "**/.designer.json": true,
    "**/.exchange.xml": true,
    "**/.vscode": true,
    "**/.mvn": true,
    "**/.tmp": true,
    "**/.settings": true,
    "**/.exchange_modules_tmp": true
  },
  "xml.preferences.showSchemaDocumentationType": "none",
  "editor.acceptSuggestionOnEnter": "on",
  "editor.wordBasedSuggestions": "off",
  "git.ignoreLimitWarning": true
}
