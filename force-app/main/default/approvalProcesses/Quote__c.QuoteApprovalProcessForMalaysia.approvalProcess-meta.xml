<?xml version="1.0" encoding="UTF-8"?>
<ApprovalProcess xmlns="http://soap.sforce.com/2006/04/metadata">
    <active>true</active>
    <allowRecall>true</allowRecall>
    <allowedSubmitters>
        <type>owner</type>
    </allowedSubmitters>
    <approvalPageFields>
        <field>Name</field>
        <field>Owner</field>
    </approvalPageFields>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <assignedApprover>
            <approver>
                <name>lixianwei1@hisense.com</name>
                <type>user</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <entryCriteria>
            <booleanFilter>1 OR 2 OR 3 OR 4 OR 5</booleanFilter>
            <criteriaItems>
                <field>Quote__c.Product_Line__c</field>
                <operation>includes</operation>
                <value>AC</value>
            </criteriaItems>
            <criteriaItems>
                <field>Quote__c.Product_Line__c</field>
                <operation>includes</operation>
                <value>LCAC</value>
            </criteriaItems>
            <criteriaItems>
                <field>Quote__c.Product_Line__c</field>
                <operation>includes</operation>
                <value>WM</value>
            </criteriaItems>
            <criteriaItems>
                <field>Quote__c.Product_Line__c</field>
                <operation>includes</operation>
                <value>Refrigerator</value>
            </criteriaItems>
            <criteriaItems>
                <field>Quote__c.Product_Line__c</field>
                <operation>includes</operation>
                <value>Freezer</value>
            </criteriaItems>
        </entryCriteria>
        <ifCriteriaNotMet>GotoNextStep</ifCriteriaNotMet>
        <label>HA Product Line Manager Approval</label>
        <name>Step_1</name>
    </approvalStep>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <assignedApprover>
            <approver>
                <name>tangdongdong@hisense.com</name>
                <type>user</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <entryCriteria>
            <booleanFilter>1 OR 2 OR 3</booleanFilter>
            <criteriaItems>
                <field>Quote__c.Product_Line__c</field>
                <operation>includes</operation>
                <value>TV</value>
            </criteriaItems>
            <criteriaItems>
                <field>Quote__c.Product_Line__c</field>
                <operation>includes</operation>
                <value>Laser TV</value>
            </criteriaItems>
            <criteriaItems>
                <field>Quote__c.Product_Line__c</field>
                <operation>includes</operation>
                <value>Mobile</value>
            </criteriaItems>
        </entryCriteria>
        <ifCriteriaNotMet>GotoNextStep</ifCriteriaNotMet>
        <label>CE Product Line Manager Approval</label>
        <name>CE_Product_Line_Manager_Approval</name>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
    </approvalStep>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <assignedApprover>
            <approver>
                <name>liquanzhi@hisense.com</name>
                <type>user</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <entryCriteria>
            <criteriaItems>
                <field>Quote__c.Gross_Profit__c</field>
                <operation>lessThan</operation>
                <value>USD 0</value>
            </criteriaItems>
        </entryCriteria>
        <label>General Manager Approval</label>
        <name>General_Manager_Approval1</name>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
    </approvalStep>
    <enableMobileDeviceAccess>false</enableMobileDeviceAccess>
    <entryCriteria>
        <criteriaItems>
            <field>Quote__c.RecordType</field>
            <operation>equals</operation>
            <value>Quote/Malaysia</value>
        </criteriaItems>
        <criteriaItems>
            <field>Quote__c.Approval_Status__c</field>
            <operation>equals</operation>
            <value>Draft,Rejected</value>
        </criteriaItems>
    </entryCriteria>
    <finalApprovalActions>
        <action>
            <name>UpdateStatusForQuoteApproved</name>
            <type>FieldUpdate</type>
        </action>
    </finalApprovalActions>
    <finalApprovalRecordLock>true</finalApprovalRecordLock>
    <finalRejectionActions>
        <action>
            <name>EmailAlertForQuoteRejected</name>
            <type>Alert</type>
        </action>
        <action>
            <name>UpdateStatusForQuoteRejected</name>
            <type>FieldUpdate</type>
        </action>
    </finalRejectionActions>
    <finalRejectionRecordLock>false</finalRejectionRecordLock>
    <initialSubmissionActions>
        <action>
            <name>UpdateStatusForQuoteSubmitted</name>
            <type>FieldUpdate</type>
        </action>
    </initialSubmissionActions>
    <label>QuoteApprovalProcessForMalaysia</label>
    <nextAutomatedApprover>
        <useApproverFieldOfRecordOwner>false</useApproverFieldOfRecordOwner>
        <userHierarchyField>Manager</userHierarchyField>
    </nextAutomatedApprover>
    <processOrder>3</processOrder>
    <recallActions>
        <action>
            <name>UpdateStatusForQuoteRecalled</name>
            <type>FieldUpdate</type>
        </action>
    </recallActions>
    <recordEditability>AdminOnly</recordEditability>
    <showApprovalHistory>true</showApprovalHistory>
</ApprovalProcess>
