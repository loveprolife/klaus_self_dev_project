<?xml version="1.0" encoding="UTF-8"?>
<ApprovalProcess xmlns="http://soap.sforce.com/2006/04/metadata">
    <active>true</active>
    <allowRecall>false</allowRecall>
    <allowedSubmitters>
        <type>owner</type>
    </allowedSubmitters>
    <approvalPageFields>
        <field>Name</field>
        <field>Owner</field>
    </approvalPageFields>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <assignedApprover>
            <approver>
                <type>adhoc</type>
            </approver>
        </assignedApprover>
        <entryCriteria>
            <booleanFilter>1 OR 2</booleanFilter>
            <criteriaItems>
                <field>Score_Sheet__c.Evaluated_Rank__c</field>
                <operation>equals</operation>
                <value>Strategy Customer</value>
            </criteriaItems>
            <criteriaItems>
                <field>Score_Sheet__c.Last_Evaluated_Rank__c</field>
                <operation>equals</operation>
                <value>Strategy Customer</value>
            </criteriaItems>
        </entryCriteria>
        <ifCriteriaNotMet>ApproveRecord</ifCriteriaNotMet>
        <label>Sales Director(Rank Update)</label>
        <name>Sales_Director_Rank_Update</name>
    </approvalStep>
    <description>v4</description>
    <enableMobileDeviceAccess>false</enableMobileDeviceAccess>
    <entryCriteria>
        <booleanFilter>1 AND 2 AND 3 AND (4 OR 5 OR 6 OR 7 OR 8)</booleanFilter>
        <criteriaItems>
            <field>Score_Sheet__c.Status__c</field>
            <operation>equals</operation>
            <value>Draft,Reject</value>
        </criteriaItems>
        <criteriaItems>
            <field>Score_Sheet__c.Evaluated_Rank__c</field>
            <operation>notEqual</operation>
            <value>Strategy Customer</value>
        </criteriaItems>
        <criteriaItems>
            <field>Score_Sheet__c.Last_Evaluated_Rank__c</field>
            <operation>notEqual</operation>
            <value>Strategy Customer</value>
        </criteriaItems>
        <criteriaItems>
            <field>User.Profile</field>
            <operation>equals</operation>
            <value>USA Sales Director</value>
        </criteriaItems>
        <criteriaItems>
            <field>User.Profile</field>
            <operation>equals</operation>
            <value>South Africa Sales Director</value>
        </criteriaItems>
        <criteriaItems>
            <field>User.Profile</field>
            <operation>equals</operation>
            <value>Malaysia Sales Director</value>
        </criteriaItems>
        <criteriaItems>
            <field>User.Profile</field>
            <operation>equals</operation>
            <value>Australia Sales Director</value>
        </criteriaItems>
        <criteriaItems>
            <field>User.Profile</field>
            <operation>equals</operation>
            <value>Mexico Sales Director</value>
        </criteriaItems>
    </entryCriteria>
    <finalApprovalActions>
        <action>
            <name>Product_Line_has_changed</name>
            <type>Task</type>
        </action>
        <action>
            <name>ScoreStatusApproved</name>
            <type>FieldUpdate</type>
        </action>
    </finalApprovalActions>
    <finalApprovalRecordLock>true</finalApprovalRecordLock>
    <finalRejectionActions>
        <action>
            <name>ScoreStatusRejected</name>
            <type>FieldUpdate</type>
        </action>
    </finalRejectionActions>
    <finalRejectionRecordLock>false</finalRejectionRecordLock>
    <initialSubmissionActions>
        <action>
            <name>ScoreStatusSubmit</name>
            <type>FieldUpdate</type>
        </action>
    </initialSubmissionActions>
    <label>Rank Update(Dir auto approve)</label>
    <nextAutomatedApprover>
        <useApproverFieldOfRecordOwner>false</useApproverFieldOfRecordOwner>
        <userHierarchyField>Manager</userHierarchyField>
    </nextAutomatedApprover>
    <processOrder>2</processOrder>
    <recordEditability>AdminOrCurrentApprover</recordEditability>
    <showApprovalHistory>true</showApprovalHistory>
</ApprovalProcess>
