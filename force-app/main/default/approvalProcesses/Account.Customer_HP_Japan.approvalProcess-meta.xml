<?xml version="1.0" encoding="UTF-8"?>
<ApprovalProcess xmlns="http://soap.sforce.com/2006/04/metadata">
    <active>true</active>
    <allowRecall>true</allowRecall>
    <allowedSubmitters>
        <type>owner</type>
    </allowedSubmitters>
    <allowedSubmitters>
        <submitter>JP_GM</submitter>
        <type>roleSubordinatesInternal</type>
    </allowedSubmitters>
    <approvalPageFields>
        <field>Name</field>
        <field>Owner</field>
        <field>Ecss_Result__c</field>
    </approvalPageFields>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <assignedApprover>
            <approver>
                <name>y.kondo@hisense.com</name>
                <type>user</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <label>Create-服务部长审批 (新服务商客户审批)</label>
        <name>Create_JP_HP_approval</name>
    </approvalStep>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <approvalActions>
            <action>
                <name>Basic_Approval_Approved</name>
                <type>FieldUpdate</type>
            </action>
            <action>
                <name>Headquarters_Approval_Submit</name>
                <type>FieldUpdate</type>
            </action>
            <action>
                <name>in_acc_fin_approve</name>
                <type>FieldUpdate</type>
            </action>
            <action>
                <name>Japan_Unlock_Tag</name>
                <type>FieldUpdate</type>
            </action>
        </approvalActions>
        <assignedApprover>
            <approver>
                <name>yanghuiyang@hisense.com</name>
                <type>user</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <label>Create-财务审批 (新服务商客户审批)</label>
        <name>Create_JP_Finance_approval</name>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
        <rejectionActions>
            <action>
                <name>acc_rejected</name>
                <type>FieldUpdate</type>
            </action>
            <action>
                <name>Basic_Approval_Rejected</name>
                <type>FieldUpdate</type>
            </action>
        </rejectionActions>
    </approvalStep>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <approvalActions>
            <action>
                <name>Japan_Unlock_Tag</name>
                <type>FieldUpdate</type>
            </action>
        </approvalActions>
        <assignedApprover>
            <approver>
                <name>weizixuan1@hisense.com</name>
                <type>user</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <entryCriteria>
            <criteriaItems>
                <field>Account.Ecss_Result__c</field>
                <operation>notEqual</operation>
                <value>ECSS Scan Result Passed</value>
            </criteriaItems>
        </entryCriteria>
        <ifCriteriaNotMet>GotoNextStep</ifCriteriaNotMet>
        <label>Create-总部法务审批 (新客户审批)</label>
        <name>Create_Customer_headquarters_approval</name>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
        <rejectionActions>
            <action>
                <name>Headquarters_Approval_Rejected</name>
                <type>FieldUpdate</type>
            </action>
        </rejectionActions>
    </approvalStep>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <assignedApprover>
            <approver>
                <name>yuhaoran2@hisense.com</name>
                <type>user</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <label>Create-总部客户管理岗 (新客户审批)</label>
        <name>Create_HQ_Manager</name>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
        <rejectionActions>
            <action>
                <name>Headquarters_Approval_Rejected</name>
                <type>FieldUpdate</type>
            </action>
        </rejectionActions>
    </approvalStep>
    <description>日本HP客户流程增加杨辉阳</description>
    <emailTemplate>unfiled$public/Customer_Onboard_Notify</emailTemplate>
    <enableMobileDeviceAccess>false</enableMobileDeviceAccess>
    <entryCriteria>
        <booleanFilter>1 AND 2 AND 3</booleanFilter>
        <criteriaItems>
            <field>Account.Approval_Status__c</field>
            <operation>contains</operation>
            <value>Draft,Rejected</value>
        </criteriaItems>
        <criteriaItems>
            <field>User.UserRole</field>
            <operation>startsWith</operation>
            <value>JP Sales HP</value>
        </criteriaItems>
        <criteriaItems>
            <field>Account.RecordType</field>
            <operation>equals</operation>
            <value>Service Vendor</value>
        </criteriaItems>
    </entryCriteria>
    <finalApprovalActions>
        <action>
            <name>acc_approved</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>Customer_Onboard_Final_Approval</name>
            <type>Alert</type>
        </action>
        <action>
            <name>Headquarters_Approval_Approved</name>
            <type>FieldUpdate</type>
        </action>
    </finalApprovalActions>
    <finalApprovalRecordLock>false</finalApprovalRecordLock>
    <finalRejectionActions>
        <action>
            <name>Acc_onboard_reject</name>
            <type>Alert</type>
        </action>
        <action>
            <name>acc_rejected</name>
            <type>FieldUpdate</type>
        </action>
    </finalRejectionActions>
    <finalRejectionRecordLock>false</finalRejectionRecordLock>
    <initialSubmissionActions>
        <action>
            <name>update_acc_approvestatus</name>
            <type>FieldUpdate</type>
        </action>
    </initialSubmissionActions>
    <label>Customer HP Japan</label>
    <nextAutomatedApprover>
        <useApproverFieldOfRecordOwner>false</useApproverFieldOfRecordOwner>
        <userHierarchyField>Manager</userHierarchyField>
    </nextAutomatedApprover>
    <processOrder>36</processOrder>
    <recallActions>
        <action>
            <name>Basic_Approval_Draft</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>Headquarters_Approval_Draft</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>update_to_draft</name>
            <type>FieldUpdate</type>
        </action>
    </recallActions>
    <recordEditability>AdminOrCurrentApprover</recordEditability>
    <showApprovalHistory>false</showApprovalHistory>
</ApprovalProcess>
