<?xml version="1.0" encoding="UTF-8"?>
<ApprovalProcess xmlns="http://soap.sforce.com/2006/04/metadata">
    <active>true</active>
    <allowRecall>true</allowRecall>
    <allowedSubmitters>
        <type>creator</type>
    </allowedSubmitters>
    <approvalPageFields>
        <field>Customer__c</field>
        <field>Customer_SAP_Code__c</field>
        <field>Name</field>
        <field>Approval_Limit__c</field>
        <field>Approval_Status__c</field>
        <field>Credit_Application_Period_days__c</field>
    </approvalPageFields>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <assignedApprover>
            <approver>
                <name>duyue1@hisense.com</name>
                <type>user</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <entryCriteria>
            <criteriaItems>
                <field>Account.Sales_Region__c</field>
                <operation>contains</operation>
                <value>Europe Sales Dept.</value>
            </criteriaItems>
            <criteriaItems>
                <field>User.Username</field>
                <operation>notEqual</operation>
                <value>duyue1@hisense.com</value>
            </criteriaItems>
        </entryCriteria>
        <ifCriteriaNotMet>GotoNextStep</ifCriteriaNotMet>
        <label>Regional General Manager Europe</label>
        <name>Regional_GM_Europe_B2B</name>
    </approvalStep>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <assignedApprover>
            <approver>
                <name>wenjin@hisense.com</name>
                <type>user</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <label>Regional General Manager</label>
        <name>Regional_General_Manager</name>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
    </approvalStep>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <assignedApprover>
            <approver>
                <name>fenglei4@hisense.com</name>
                <type>user</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <label>Financial Risk Control Post</label>
        <name>Financial_Risk_Control_Post</name>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
    </approvalStep>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <assignedApprover>
            <approver>
                <name>dingzhihong@hisense.com</name>
                <type>user</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <label>Overseas Financial Officer</label>
        <name>Overseas_Financial_Officer</name>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
    </approvalStep>
    <description>B2B 客户信用额度审批流程New</description>
    <emailTemplate>unfiled$public/HA_CE_Credit_Limit_Application_Email</emailTemplate>
    <enableMobileDeviceAccess>false</enableMobileDeviceAccess>
    <entryCriteria>
        <booleanFilter>1 AND 2 AND (3 OR 4 OR 5)</booleanFilter>
        <criteriaItems>
            <field>Credit_Limit_Application__c.Approval_Status__c</field>
            <operation>contains</operation>
            <value>Draft,Rejected,Risk Post Rejected,Risk Management Committee Rejected,Insurance Company Rejected</value>
        </criteriaItems>
        <criteriaItems>
            <field>User.Division</field>
            <operation>equals</operation>
            <value>商用显示公司</value>
        </criteriaItems>
        <criteriaItems>
            <field>Account.Sales_Region__c</field>
            <operation>contains</operation>
            <value>Hisense USA,NA OEM Sales Dept.,Hisense South Africa,Hisense Dubai,Hisense Canada,Hisense Mexico,Hisense Panama,Hisense Colombia,Hisense Peru,Hisense Brazil,Hisense Chile,Hisense Argentina,Hisense Australia,Hisense New Zealand,Hisense India</value>
        </criteriaItems>
        <criteriaItems>
            <field>Account.Sales_Region__c</field>
            <operation>contains</operation>
            <value>South Asia Office,East Asia Office,Europe Sales Dept.,Hisense Russia - Direct Sales,Israel Office,Hisense Indonesia,Hisense Malaysia</value>
        </criteriaItems>
        <criteriaItems>
            <field>Account.Sales_Region__c</field>
            <operation>contains</operation>
            <value>Asia-Pacific Sales Department</value>
        </criteriaItems>
    </entryCriteria>
    <finalApprovalActions>
        <action>
            <name>Update_Approval_Status_to_RR_Approving</name>
