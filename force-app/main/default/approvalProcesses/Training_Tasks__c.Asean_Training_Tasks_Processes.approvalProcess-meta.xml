<?xml version="1.0" encoding="UTF-8"?>
<ApprovalProcess xmlns="http://soap.sforce.com/2006/04/metadata">
    <active>true</active>
    <allowRecall>true</allowRecall>
    <allowedSubmitters>
        <type>owner</type>
    </allowedSubmitters>
    <approvalPageFields>
        <field>Name</field>
        <field>Year__c</field>
        <field>Month__c</field>
        <field>Employee_Name__c</field>
        <field>Store__c</field>
        <field>Training_Address__c</field>
        <field>Training_Theme__c</field>
        <field>Training_Start_Time__c</field>
        <field>Training_End_Time__c</field>
    </approvalPageFields>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <assignedApprover>
            <approver>
                <name>zhengyouming@hisense.com</name>
                <type>user</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <entryCriteria>
            <criteriaItems>
                <field>User.Sales_Region__c</field>
                <operation>equals</operation>
                <value>Hisense Malaysia</value>
            </criteriaItems>
        </entryCriteria>
        <ifCriteriaNotMet>GotoNextStep</ifCriteriaNotMet>
        <label>Further approval</label>
        <name>Further_approval</name>
    </approvalStep>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <assignedApprover>
            <approver>
                <name>zhengyouming@hisense.com</name>
                <type>user</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <entryCriteria>
            <criteriaItems>
                <field>User.Sales_Region__c</field>
                <operation>equals</operation>
                <value>Hisense Indonesia</value>
            </criteriaItems>
        </entryCriteria>
        <ifCriteriaNotMet>GotoNextStep</ifCriteriaNotMet>
        <label>Further approval</label>
        <name>Further_approval1</name>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
    </approvalStep>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <assignedApprover>
            <approver>
                <name>zhengyouming@hisense.com</name>
                <type>user</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <entryCriteria>
            <criteriaItems>
                <field>User.Sales_Region__c</field>
                <operation>equals</operation>
                <value>Hisense Thailand,Hisense Vietnam,Hisense Singapore</value>
            </criteriaItems>
        </entryCriteria>
        <label>Further approval</label>
        <name>Further_approval2</name>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
    </approvalStep>
    <description>东盟培训任务审批</description>
    <emailTemplate>TrainingTask/TrainingTaskApproval</emailTemplate>
    <enableMobileDeviceAccess>true</enableMobileDeviceAccess>
    <entryCriteria>
        <criteriaItems>
            <field>Training_Tasks__c.Status__c</field>
            <operation>notContain</operation>
            <value>预有效,有效</value>
        </criteriaItems>
        <criteriaItems>
            <field>User.Sales_Region__c</field>
            <operation>contains</operation>
            <value>Hisense Malaysia,Hisense Thailand,Hisense Indonesia,Hisense Vietnam,Hisense Singapore</value>
        </criteriaItems>
    </entryCriteria>
    <finalApprovalActions>
        <action>
            <name>Training_Task_Status_Effective</name>
            <type>FieldUpdate</type>
        </action>
    </finalApprovalActions>
    <finalApprovalRecordLock>true</finalApprovalRecordLock>
    <finalRejectionActions>
        <action>
            <name>Training_Task_Status_Invalid</name>
            <type>FieldUpdate</type>
        </action>
    </finalRejectionActions>
    <finalRejectionRecordLock>false</finalRejectionRecordLock>
    <initialSubmissionActions>
        <action>
            <name>Training_Task_Status_Pre_effective</name>
            <type>FieldUpdate</type>
        </action>
    </initialSubmissionActions>
    <label>Asean Training Tasks Processes</label>
    <nextAutomatedApprover>
        <useApproverFieldOfRecordOwner>false</useApproverFieldOfRecordOwner>
        <userHierarchyField>Manager</userHierarchyField>
    </nextAutomatedApprover>
    <processOrder>1</processOrder>
    <recallActions>
        <action>
            <name>Training_Task_Status_Null</name>
            <type>FieldUpdate</type>
        </action>
    </recallActions>
    <recordEditability>AdminOrCurrentApprover</recordEditability>
    <showApprovalHistory>true</showApprovalHistory>
</ApprovalProcess>
