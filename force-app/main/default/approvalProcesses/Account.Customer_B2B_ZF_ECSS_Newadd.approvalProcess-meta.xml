<?xml version="1.0" encoding="UTF-8"?>
<ApprovalProcess xmlns="http://soap.sforce.com/2006/04/metadata">
    <active>false</active>
    <allowRecall>true</allowRecall>
    <allowedSubmitters>
        <type>owner</type>
    </allowedSubmitters>
    <approvalPageFields>
        <field>Name</field>
        <field>Owner</field>
        <field>Ecss_Result__c</field>
    </approvalPageFields>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <assignedApprover>
            <approver>
                <name>duyue1@hisense.com</name>
                <type>user</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <entryCriteria>
            <criteriaItems>
                <field>Account.Sales_Region__c</field>
                <operation>contains</operation>
                <value>Europe Sales Dept.</value>
            </criteriaItems>
        </entryCriteria>
        <ifCriteriaNotMet>GotoNextStep</ifCriteriaNotMet>
        <label>Create-Regional General Manager Europe (New Customer Approval)</label>
        <name>Create_Regional_General_Manager_Europe_Customer_Onboard</name>
    </approvalStep>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <assignedApprover>
            <approver>
                <name>wenjin@hisense.com</name>
                <type>user</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <label>Create-General Manager of Overseas Business Department (New Customer Approval)</label>
        <name>Create_General_Manager_of_Overseas_Business_Department_Customer_Onboard</name>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
    </approvalStep>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <assignedApprover>
            <approver>
                <name>weizixuan1@hisense.com</name>
                <type>user</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <entryCriteria>
            <criteriaItems>
                <field>Account.Ecss_Result__c</field>
                <operation>notEqual</operation>
                <value>ECSS Scan Result Passed</value>
            </criteriaItems>
        </entryCriteria>
        <ifCriteriaNotMet>GotoNextStep</ifCriteriaNotMet>
        <label>Create-Group Legal Affairs (New Customer Approval)</label>
        <name>Create_Group_Legal_Affairs_Customer_Onboard</name>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
    </approvalStep>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <approvalActions>
            <action>
                <name>in_acc_fin_approve</name>
                <type>FieldUpdate</type>
            </action>
        </approvalActions>
        <assignedApprover>
            <approver>
                <name>fenglei4@hisense.com</name>
                <type>user</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <label>Create-Headquarters Finance (New Customer Approval)</label>
        <name>Create_Headquarters_Finance_Customer_Onboard</name>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
    </approvalStep>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <assignedApprover>
            <approver>
                <name>dingzhihong@hisense.com</name>
                <type>user</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <label>Create-Overseas Financial Officer (New Customer Approval)</label>
        <name>Create_Overseas_Financial_Officer_New_Customer_Approval</name>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
    </approvalStep>
    <description>直发业务创建客户审批流程：销售经理（申请）-大区总（亚太：温金；美国：温金; 南非：温金；迪拜：温金。欧洲：杜悦；）--海外业务部总经理（温金)--集团法务（魏孜轩）-总部财务（冯磊）-丁志红</description>
    <emailTemplate>unfiled$public/Customer_Onboard_Notify</emailTemplate>
    <enableMobileDeviceAccess>false</enableMobileDeviceAccess>
    <entryCriteria>
        <booleanFilter>1 AND 2 AND (3 OR 4) AND (5 OR 6)</booleanFilter>
        <criteriaItems>
            <field>Account.Approval_Status__c</field>
            <operation>contains</operation>
            <value>Draft,Rejected</value>
        </criteriaItems>
        <criteriaItems>
            <field>Account.RecordType</field>
            <operation>equals</operation>
            <value>B2B customer</value>
        </criteriaItems>
        <criteriaItems>
            <field>Account.Hisense_Entity__c</field>
            <operation>contains</operation>
            <value>8000,8010,8040,8050,8060,8070,8080,8090</value>
        </criteriaItems>
        <criteriaItems>
            <field>Account.Hisense_Entity__c</field>
            <operation>contains</operation>
            <value>80A0,80B0,80F0,80G0,80K0,80Q0</value>
        </criteriaItems>
        <criteriaItems>
            <field>Account.Sales_Region__c</field>
            <operation>contains</operation>
            <value>Hisense USA,NA OEM Sales Dept.,Hisense South Africa,Hisense Dubai,Hisense Canada,Hisense Mexico,Hisense Panama,Hisense Colombia,Hisense Peru,Hisense Brazil,Hisense Chile,Hisense Argentina,Hisense Australia,Hisense New Zealand,Hisense India</value>
        </criteriaItems>
        <criteriaItems>
            <field>Account.Sales_Region__c</field>
            <operation>contains</operation>
            <value>South Asia Office,East Asia Office,Europe Sales Dept.,Hisense Russia - Direct Sales,Israel Office,Asia-Pacific Sales Department</value>
        </criteriaItems>
    </entryCriteria>
    <finalApprovalActions>
        <action>
            <name>acc_approved</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>Customer_Onboard_Final_Approval</name>
            <type>Alert</type>
        </action>
        <action>
            <name>restoreFin</name>
            <type>FieldUpdate</type>
        </action>
    </finalApprovalActions>
    <finalApprovalRecordLock>false</finalApprovalRecordLock>
    <finalRejectionActions>
        <action>
            <name>Acc_onboard_reject</name>
            <type>Alert</type>
        </action>
        <action>
            <name>acc_rejected</name>
            <type>FieldUpdate</type>
        </action>
    </finalRejectionActions>
    <finalRejectionRecordLock>false</finalRejectionRecordLock>
    <initialSubmissionActions>
        <action>
            <name>update_acc_approvestatus</name>
            <type>FieldUpdate</type>
        </action>
    </initialSubmissionActions>
    <label>Customer Onboard B2B 直发Newadd</label>
    <nextAutomatedApprover>
        <useApproverFieldOfRecordOwner>false</useApproverFieldOfRecordOwner>
        <userHierarchyField>Manager</userHierarchyField>
    </nextAutomatedApprover>
    <processOrder>2</processOrder>
    <recallActions>
        <action>
            <name>update_to_draft</name>
            <type>FieldUpdate</type>
        </action>
    </recallActions>
    <recordEditability>AdminOrCurrentApprover</recordEditability>
    <showApprovalHistory>false</showApprovalHistory>
</ApprovalProcess>
