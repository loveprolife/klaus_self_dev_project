global class InspectionPhotoNameSchedule implements Schedulable{
    public String salesRegion;

    // 添加构造函数
    global InspectionPhotoNameSchedule() {
        
    }

    global void execute(SchedulableContext sc) {
        changePhotoName();
    }

    //按照SalesRegion查询图片进行更新
    public static void changePhotoName(){
        try {                    
            if(Test.isRunningTest()){
                gabige();
            }
            // 获取当天的日期
            Date today = Date.today();
            Date previousDate = today.addDays(-1); 
            // Date previousDate = Date.newInstance(2025, 7, 14);
            // 构造当天的开始时间（00:00:00）
            DateTime previousStart = DateTime.newInstanceGmt(previousDate, Time.newInstance(0, 0, 0, 0));
            
            DateTime previousEnd = DateTime.newInstanceGmt(previousDate, Time.newInstance(23, 59, 59, 999));

            System.debug('previousStart: ' + previousStart);
            System.debug('previousEnd: ' + previousEnd);
            // List<Sampling_Inspection__c> testList = [SELECT Id, Inspection_Report__r.Report_Date__c, Shop__r.Name, Shop__r.Channel_Name__c, Inspection_Report__r.Sales_Region__c, CreatedBy.Name  FROM Sampling_Inspection__c WHERE Inspection_Report__r.CreatedDate >= :previousStart AND Inspection_Report__r.CreatedDate <= :previousEnd AND Shop__r.Name = 'Carrefour-Av. Ferre 2985-Corrientes'];
            // System.debug('TESTLIST: ' + testList.size());
            Map<String, Object> resp = new Map<String, Object>(); 
            List<ContentVersion> entitiesToUpdate = new List<ContentVersion>();
            //按照国家分块防止ID重叠
            Map<String, Set<Id>> sbuCheckIdMap = new Map<String, Set<Id>>();
            Map<String, Set<Id>> sbuSampleIdMap = new Map<String, Set<Id>>();
            Set<Id> idList = new Set<Id>();
            Set<Id> sampleIdList = new Set<Id>();
            List<CheckResult__c> checkList = [SELECT Id,Sales_Region__c, InspectorDailyReport__r.Report_Date__c, InspectorDailyReport__r.Store__r.Name, InspectorDailyReport__r.Store__r.Channel_Name__c, CheckItem__r.Item_Type__c, Result__c, CreatedBy.Name FROM CheckResult__c WHERE InspectorDailyReport__r.CreatedDate >= :previousStart AND InspectorDailyReport__r.CreatedDate <= :previousEnd ];
            // List<Sampling_Inspection__c> sampleList = new List<Sampling_Inspection__c>();
            List<Sampling_Inspection__c> sampleList = [SELECT Id,Sales_Region__c, Inspection_Report__r.Report_Date__c, Shop__r.Name, Shop__r.Channel_Name__c, CreatedBy.Name  FROM Sampling_Inspection__c WHERE Inspection_Report__r.CreatedDate >= :previousStart AND Inspection_Report__r.CreatedDate <= :previousEnd ];
            // 遍历查询结果并分组
            for (CheckResult__c checkResult : checkList) {
                String salesRegion = checkResult.Sales_Region__c;
                if (!sbuCheckIdMap.containsKey(salesRegion)) {
                    sbuCheckIdMap.put(salesRegion, new Set<Id>());
                }
                sbuCheckIdMap.get(salesRegion).add(checkResult.Id);
            }
            for (Sampling_Inspection__c inspection : sampleList) {
                String salesRegion = inspection.Sales_Region__c;
                if (!sbuSampleIdMap.containsKey(salesRegion)) {
                    sbuSampleIdMap.put(salesRegion, new Set<Id>());
                }
                sbuSampleIdMap.get(salesRegion).add(inspection.Id);
            }

            System.debug('参数' + sbuCheckIdMap.keySet());
            System.debug('参数' + sbuSampleIdMap.keySet());

            // for (CheckResult__c result : checkList) {
            //     idList.add(result.Id);
            // }
            // for (Sampling_Inspection__c result : sampleList) {
            //     sampleIdList.add(result.Id);
            // }
            if (sbuCheckIdMap.isEmpty() && sbuSampleIdMap.isEmpty()) {
                System.debug('没有数据');
                return;
            }
            if(!sbuCheckIdMap.isEmpty() ) {
                for(String salesRegion : sbuCheckIdMap.keySet()) {
                    System.debug('CheckResult:' + salesRegion);
                    List<ContentDocumentLink> contentDocumentList = [SELECT Id, LinkedEntityId, ContentDocument.LatestPublishedVersionId
                                                                     FROM ContentDocumentLink
                                                                     WHERE LinkedEntityId IN :sbuCheckIdMap.get(salesRegion)];
                    Map<String, List<ContentDocumentLink>> entityMap = new Map<String, List<ContentDocumentLink>>();
                    
                    if (contentDocumentList.size() == 0) {
                        continue; 
                    }
                    for (ContentDocumentLink entity : contentDocumentList) {
                        String key = String.valueOf(entity.LinkedEntityId)+ String.valueOf(entity.Id);
                        if (!entityMap.containsKey(key)) {
                            entityMap.put(key, new List<ContentDocumentLink>());
                        }
                        entityMap.get(key).add(entity);

                    }
                    System.debug('包含图片Size=' + entityMap.size());
                    Map<Id, CheckResult__c> checkResultMap = new Map<Id, CheckResult__c>();
                    for (CheckResult__c checkResult : checkList) {
                        checkResultMap.put(checkResult.Id, checkResult);
                    }

                    Map<String, Integer> itemTypeCountMap = new Map<String, Integer>();
                    for (String linkedEntityId : entityMap.keySet()) {
                        List<ContentDocumentLink> DocumentEntity =  entityMap.get(linkedEntityId);
                        String documentId = DocumentEntity[0].LinkedEntityId;
                        CheckResult__c checkResult = checkResultMap.get(documentId);
                        if (checkResult == null) {
                            System.debug('No CheckResult__c found for LinkedEntityId: ' + documentId);
                            continue;
                        }
                        // 按 Item_Type__c 分组
                        for (ContentDocumentLink entity : entityMap.get(linkedEntityId)) {
                            String itemType = checkResult.CheckItem__r.Item_Type__c;
                            String region = checkResult.Sales_Region__c;
                            String storeName = checkResult.InspectorDailyReport__r.Store__r.Name;
                            String creatName = checkResult.CreatedBy.Name;
                            String formattedDate = String.valueOf(checkResult.InspectorDailyReport__r.Report_Date__c);
                            String key = region +'_'+ storeName+'_'+ itemType +'_'+ creatName + '-' + formattedDate;
                            Integer count = itemTypeCountMap.get(key) == null ? 1 : itemTypeCountMap.get(key) + 1;
                            itemTypeCountMap.put(key, count);
                            String newName = checkResult.InspectorDailyReport__r.Store__r.Channel_Name__c + '_'
                                             + checkResult.InspectorDailyReport__r.Store__r.Name + '_'
                                             + itemType + '_'
                                             + formattedDate + '_'
                                             + count;

                            ContentVersion contentVersion = new ContentVersion();
                            contentVersion.Title = newName;
                            contentVersion.Id = entity.ContentDocument.LatestPublishedVersionId;
                            entitiesToUpdate.add(contentVersion);
                        }
                    }
                }                
            }

            if (!sbuSampleIdMap.isEmpty() ){
                for(String salesRegion : sbuSampleIdMap.keySet()) {
                    System.debug('Sample:' + salesRegion);
                    List<ContentDocumentLink> contentDocumentList = [SELECT Id, LinkedEntityId, ContentDocument.LatestPublishedVersionId
                                                                     FROM ContentDocumentLink
                                                                     WHERE LinkedEntityId IN :sbuSampleIdMap.get(salesRegion)];
                    Map<String, List<ContentDocumentLink>> entityMap = new Map<String, List<ContentDocumentLink>>();
                    if (contentDocumentList.size() > 0) {
                        for (ContentDocumentLink entity : contentDocumentList) {
                            String key = String.valueOf(entity.LinkedEntityId)+ String.valueOf(entity.Id);
                            if (!entityMap.containsKey(key)) {
                                entityMap.put(key, new List<ContentDocumentLink>());
                            }
                            entityMap.get(key).add(entity);
                        }
                        Map<Id, Sampling_Inspection__c> checkResultMap = new Map<Id, Sampling_Inspection__c>();
                        for (Sampling_Inspection__c checkResult : sampleList) {
                            checkResultMap.put(checkResult.Id, checkResult);
                        }
                        
                        Map<String, Integer> itemTypeCountMap = new Map<String, Integer>();
                        for (String linkedEntityId : entityMap.keySet()) {
                            List<ContentDocumentLink> DocumentEntity =  entityMap.get(linkedEntityId);
                            String documentId = DocumentEntity[0].LinkedEntityId;     
                            Sampling_Inspection__c checkResult = checkResultMap.get(documentId);
                            if (checkResult == null) {
                                System.debug('No CheckResult__c found for LinkedEntityId: ' + documentId);
                                continue;
                            }
                            for (ContentDocumentLink entity : entityMap.get(linkedEntityId)) {
                                String itemType = System.Label.Sample_Display;
                                String storeName = checkResult.Shop__r.Name;
                                String creatName = checkResult.CreatedBy.Name;
                                String region = checkResult.Sales_Region__c;
                                String formattedDate = String.valueOf(checkResult.Inspection_Report__r.Report_Date__c);
                                String key = region +'_'+ storeName+'_'+ itemType +'_'+ creatName + '-' + formattedDate;                
                                Integer count = itemTypeCountMap.get(key) == null ? 1 : itemTypeCountMap.get(key) + 1;
                                itemTypeCountMap.put(key, count);
                                String newName = checkResult.Shop__r.Channel_Name__c + '_' + checkResult.Shop__r.Name + '_' + itemType + '_' + formattedDate + '_' + count;
                                ContentVersion contentVersion = new ContentVersion();
                                contentVersion.Title = newName;
                                contentVersion.Id = entity.ContentDocument.LatestPublishedVersionId;
                                entitiesToUpdate.add(contentVersion);
                            }
                        }
                    } else {
                        System.debug(salesRegion + '无抽样图片');
                    }

                }
            }
            
            System.debug('' + entitiesToUpdate.size());
            Utility.insertLog('InspectionPhotoNameSchedule', '1', null,  '-----' + entitiesToUpdate.size());
            // 更新 ContentVersion 记录
            if (!entitiesToUpdate.isEmpty()) {
                update entitiesToUpdate;
            }
        } catch (Exception e) {
            system.debug('error message'+e.getMessage());
            Utility.insertLog('InspectionPhotoNameSchedule', '0', null,  '-----' + e.getMessage());
        }        
    }

