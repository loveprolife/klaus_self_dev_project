   //查找客户下的销售组织
   @AuraEnabled(cacheable = true)
   public static list<sObject> searchSalesOrgLookupData(string searchKey, string sObjectApiName){
        String parentUserId = UserInfo.getUserId();//当前记录ID
       List<sObject> returnList = new List<sObject>();
       string sWildCardText = '%' + searchKey + '%';
       string sQuery = 'Select Id,Name,Email__c From SubUser__c Where  ParentUser__c =:parentUserId and (Name Like : sWildCardText or Email__c Like : sWildCardText) and IsActive__c = true  order by createdDate ASC LIMIT 20';
       System.debug(sQuery);
       
       for (sObject obj : database.query(sQuery)){
            System.debug(obj);
           returnList.add(obj);
       }
       return returnList;
   }

    // Method to fetch lookup default value
    @AuraEnabled
    public static sObject searchDefaultRecord(string recordId, string sObjectApiName){
        string sRecId = recordId;
        string sQuery = 'Select Id,Name,Email__c From SubUser__c Where Id = : sRecId LIMIT 1';
        for (sObject obj : database.query(sQuery)){
            return obj;
        }
        return null;
    }
    @AuraEnabled
    public static StoreInfo getStoreId(String subUserId) {
        // 确保传入的 subUserId 不为空
        if (String.isBlank(subUserId)) {
            return null;  // 或者返回一个适当的默认值
        }
        
        try {
            // 查询 SubStore__c 对象，查找与 subUserId 匹配的记录
            SubStore__c storeRecord = [SELECT StoreID__c, StoreID__r.Name FROM SubStore__c WHERE SubUserID__c = :subUserId LIMIT 1];
            
            // 检查是否找到匹配的记录
            if (storeRecord != null) {
                // 返回 StoreInfo 对象，包含 StoreID 和 StoreName
                return new StoreInfo(storeRecord.StoreID__c, storeRecord.StoreID__r.Name);
            } else {
                return null;  // 或者返回一个默认值
            }
        } catch (QueryException e) {
            // 如果查询出现问题，捕获异常并记录错误信息
            System.debug('Error occurred while querying SubStore__c: ' + e.getMessage());
            return null;  // 返回 null 或者你希望的默认值
        }
    }
    public class StoreInfo {
        @AuraEnabled public String storeId;
        @AuraEnabled public String storeName;
    
        // 构造函数
        public StoreInfo(String storeId, String storeName) {
            this.storeId = storeId;
            this.storeName = storeName;
        }
    }

