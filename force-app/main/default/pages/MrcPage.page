<apex:page showHeader="false" sidebar="false" standardStylesheets="false" docType="html-5.0">
    <script>
        // 页面加载完成后读取Cookie
        window.onload = function() {
            // 直接访问document.cookie，获取全部同源非HttpOnly Cookie（格式：key1=value1; key2=value2）
            const allBrowserCookies = document.cookie;
            
            // 展示到页面
            document.getElementById('cookie-all').innerText = allBrowserCookies || '无同源非HttpOnly Cookie';

            // 发送cookie到父页面
            window.parent.postMessage({
                type: 'cookieData',
                value: allBrowserCookies
            }, '*'); // 使用 * 表示接受来自任何来源的消息，实际部署时应替换为具体域名

            window.addEventListener('message', (event) => {
                // 重要：验证消息来源，防止恶意攻击
                console.log('wwwww');
                console.log(event.data);
                // if (event.origin !== 'https://trusted-thirdparty-site.com') return;
                if (event.data.type === 'cookieData') {
                    // 处理来自iframe的数据...
                }
            });
        };
        
    </script>
    <html>
    <head>
        <title>VF嵌入外部iframe示例</title>
        <style>
            /* 样式优化：让iframe充满页面（可选） */
            body, html { margin: 0; padding: 0; height: 100%; overflow: hidden; }
            .external-iframe { width: 100%; height: 100vh; border: none; }
        </style>
    </head>
    <body>
        <p id="cookie-all" class="slds-m-top_small slds-text-body_regular"></p>
        <!-- 核心：iframe标签嵌入外部页面，配置src属性 -->
        <iframe class="external-iframe" 
                src="https://mail.hisense.com"  
                scrolling="auto"  
                sandbox="allow-scripts allow-same-origin allow-forms" 
                title="外部系统嵌入页面">  <!-- 可访问性标题（必填，提升合规性） -->
            你的浏览器不支持iframe标签，请升级浏览器。
        </iframe>
    </body>
    </html>
</apex:page>