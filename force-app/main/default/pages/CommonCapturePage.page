                                    <use xmlns:xlink="http://www.w3.org/1999/xlink"
                                    xlink:href="/apexpages/slds/latest/assets/icons/utility-sprite/svg/symbols.svg#photo">
                                    </use>
                                    </svg>
                                    <span class="slds-assistive-text">photo</span>
                                </button>
                            </td>
                            <td style="padding: 20px; text-align: center; width: 33%;">
                                <button id="showlwc" class="slds-button slds-button_icon slds-button_icon-border slds-button_icon-large">
                                    <svg class="slds-button__icon" aria-hidden="true">
                                     <use xmlns:xlink="http://www.w3.org/1999/xlink"
