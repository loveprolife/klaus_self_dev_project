                </div>
                <video id="video" width="1920" height="2560" style="width:100%;"/>
                <canvas id="canvas" width="1920" height="2560" style="background:#FAF0E6;display:none;"></canvas>
                <div>
                    <table>
                        <!-- <tr>
                            <td colspan="3" style="padding: 20px; text-align: center;">
                                <select id="faceMode">
                                    <option value="user" selected="selected">front-facing camera</option>
                                    <option value="environment">rear camera</option>
                                </select>
                            </td>
                        </tr> -->
                        <tr>
                            <td style="padding: 20px; text-align: center; width: 33%;">
                                <button id="closelwc" class="slds-button slds-button_icon slds-button_icon-border slds-button_icon-large">
