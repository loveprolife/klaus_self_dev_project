<!--
  CofaceCallBackPage
  On load, creates a new Account record and redirects to it.
  Optional URL param: ?name=Custom+Account+Name
-->
<apex:page controller="CofaceCallBackController" action="{!createAccountOnInit}">
    <apex:pageMessages />
    <!-- If not redirected (e.g., error), show simple message -->
    <apex:outputPanel >
        <h2>Initializing...</h2>
        <p>If you are seeing this message, the redirect did not occur. Please review the error messages above.</p>
    </apex:outputPanel>
</apex:page>