<apex:page controller="LocationController" showHeader="false" sidebar="false">
<html xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink">
    <head>
        <style>
            .custom-info-window { 
                padding: 0px 10px 10px 10px;
            }
            .action-button {
                float: right;
                background: #007bff;
                color: white;
                border: none;
                padding: 8px 12px;
                border-radius: 4px;
                cursor: pointer;
            }
            .input{
                height: 30px
            }
            .custom-icon{
                width: 40px;
                height: 30px;
            }
            .custom-div{
                display: flex;
                justify-content: center; /* 水平居中 */
                align-items: center;     /* 垂直居中 */
            }
        </style>
    </head>
    
    <script>
        let map;
        let geocoder;
        let placesService;
        let marker;
        let latitude = 36.1405;
        let longitude = 120.4755;
        let infoWindow;
        let storeAddress;
        let addressDetails = { country: '', province: '', city: '', street: '' };
        let directionsRenderer;
        let markers = [];

        // const params = new URLSearchParams(window.location.search);
        // if(params.get('param1') != undefined && params.get('param1') != null && params.get('param1') != ''){
        //     latitude = Number(params.get('param1'));
        // }
        // if(params.get('param2') != undefined && params.get('param2') != null && params.get('param2') != ''){
        //     longitude = Number(params.get('param2'));
        // }
        
        // 初始化位置信息及地图
        function initPosition() {
            // // 获取用户授权并定位
            // if (navigator.geolocation) {
            //     navigator.geolocation.getCurrentPosition(
            //         function(position) {
            //             // 成功回调：输出经纬度
            //             latitude = position.coords.latitude;
            //             longitude = position.coords.longitude;
            //             console.log('当前定位纬度:', latitude, '当前定位经度:', longitude);
            //             initMap();
            //         },
            //         function(error) {
            //             initMap();
            //             // 失败回调：处理错误类型
            //             switch(error.code) {
            //                 case error.PERMISSION_DENIED:
            //                     alert('用户拒绝定位授权');
            //                     break;
            //                 case error.POSITION_UNAVAILABLE:
            //                     alert('无法获取位置信息');
            //                     break;
            //                 case error.TIMEOUT:
            //                     alert('定位请求超时');
            //                     break;
            //             }
            //         }
            //     );
            // } else {
            //     initMap();
            //     alert('当前浏览器不支持定位功能');
            // }

            console.log('当前定位纬度----:', latitude, '当前定位经度----:', longitude);
            initMap();

            // 绑定搜索框
            const searchBox = new google.maps.places.SearchBox(document.getElementById('search-input'));
            searchBox.addListener('places_changed', () => {
                const places = searchBox.getPlaces();
                if (places.length === 0) return;
                console.log(places);
                map.fitBounds(places[0].geometry.viewport);

                const location = places[0].geometry.location;
                storeAddress = places[0].formatted_address;
                console.log('查询地址的纬度:', location.lat(), '查询地址的经度:', location.lng());
                marker.setPosition(places[0].geometry.location);
                
                if(places[0].address_components != undefined && places[0].address_components != null && places[0].address_components != ''){
                    getAddressDetails(places[0].address_components);
                }else {
                    getAddressDetailsBylatLng(places[0].geometry.location);
                }

                marker.addListener("click", ({ domEvent, latLng }) => {
                const { target } = domEvent;
                const content = `
                    <div id="content" class="custom-info-window">
                        <div id="siteNotice"></div>
                        <div>
                            <p>
                            位置信息：<br>
                            地址：${places[0].formatted_address}<br>
                            纬度: ${location.lat().toFixed(6)}<br>
                            经度: ${location.lng().toFixed(6)}</p>
                            <button class="action-button" onclick="handleAddStore(${location.lat()}, ${location.lng()})">
                                New Store
                            </button>
                        </div>
                    </div>
                `;
                infoWindow.close();
                infoWindow.setContent(content);
                infoWindow.open(marker.map, marker);
            });

                showShopInfo(location.lat(), location.lng(), 10);
            });

            // 绑定开始地址搜索框
            const startLocation = new google.maps.places.SearchBox(document.getElementById('start-location'));
            startLocation.addListener('places_changed', () => {
                const places = startLocation.getPlaces();
                if (places.length === 0) return;

                const location = places[0].geometry.location;
                console.log('查询start-location的纬度:', location.lat(), '查询start-location的经度:', location.lng());
            });

            // 绑定结束地址搜索框
            const endLocation = new google.maps.places.SearchBox(document.getElementById('end-location'));
            endLocation.addListener('places_changed', () => {
                const places = endLocation.getPlaces();
                if (places.length === 0) return;

                const location = places[0].geometry.location;
                console.log('查询end-location的纬度:', location.lat(), '查询end-location的经度:', location.lng());
            });

            
        }

        // 初始化google地图
        function initMap(){
            map = new google.maps.Map(document.getElementById('map'), {
                zoom: 14,
                center: { lat:  latitude, lng: longitude } ,
                mapId:'112233445566778899'
            });
            marker = new google.maps.Marker({
                // position :{ lat: Number(latitude), lng: Number(longitude) },
                map: map,
                title: "当前定位",
                gmpClickable: true,
            });

            directionsRenderer = new google.maps.DirectionsRenderer();
            directionsRenderer.setMap(map); // 绑定渲染器到地图

            geocoder = new google.maps.Geocoder();
            placesService = new google.maps.places.PlacesService(map);

            // 初始化信息窗口
            infoWindow = new google.maps.InfoWindow();

            // 绑定地图点击事件
            map.addListener('click', (event) => {
                console.log(event);
                const lat = event.latLng.lat();
                const lng = event.latLng.lng();
                console.log('鼠标点击的纬度:', lat, '鼠标点击的经度:', lng);
                updateMarker(lat, lng);

                if(event.placeId != undefined && event.placeId != '' && event.placeId != null){
                    const request = {
                        placeId: event.placeId,
                        fields: ['name', 'formatted_address', 'geometry', 'photos']
                    };
                    placesService.getDetails(request, (place, status) => {
                        if (status === google.maps.places.PlacesServiceStatus.OK) {
                            // 获取到地址信息后，进行处理
                            console.log('Place name:', place.name);  // 地点名称
                            console.log('Formatted address:', place.formatted_address);  // 地址
                            console.log('Place geometry:', place.geometry);  // 地点坐标
                            marker.setPosition(place.geometry.location);
                            showInfoWindow(marker, event, place.name, place.formatted_address);
                        }
                    });
                }else {
                    geocoder.geocode({ location: event.latLng }, (results, status) => {
                        if (status === 'OK' && results) {
                            console.log(results);
                            const address = results[0].formatted_address; // 获取完整地址‌:ml-citation{ref="6,8" data="citationList"}
                            console.log('鼠标点击的地址:', address);
                            marker.setPosition(results[0].geometry.location);
                            
                            getAddressDetails(results[0].address_components);
                            showInfoWindow(marker, event, '', address);
                        }
                    });
                }
            });

            showShopInfo(latitude, longitude, 10);
        }

        function showShopInfo(latitude, longitude, distance){
            // 清空门店数据
            clearMarkers();
            // 异步加载 Salesforce 数据 
            Visualforce.remoting.Manager.invokeAction(
                '{!$RemoteAction.LocationController.getShop}',
                latitude,
                longitude,
                10,
                function(result) {
                    result.forEach(shop => {
                        const pinBackground = new google.maps.marker.PinElement({
                            background: '#FBBC04',
                            scale: 1.3,
                        });
                        const marker = new google.maps.marker.AdvancedMarkerElement({
                            position: { lat: shop.Shop_Center_Location__Latitude__s, lng: shop.Shop_Center_Location__Longitude__s },
                            map: map,
                            title: shop.Name,
                            content: pinBackground.element,
                            gmpClickable: true,
                        });
                        // Add a click listener for each marker, and set up the info window.
                        marker.addListener("click", ({ domEvent, latLng }) => {
                            const { target } = domEvent;
                            const content = `
                                <div id="content" class="custom-info-window">
                                    <div id="siteNotice"></div>
                                    <h1 id="firstHeading" >门店名称: 
                                        <a href="/lightning/r/Shop__c/${shop.Id}/view" target="_blank" style="color: #007bff; text-decoration: none">${shop.Name}</a>
                                    </h1>
                                    <div>
                                        <p>
                                        位置信息：<br>
                                        地址：${shop.City__c != null ? shop.City__c : ''}${shop.Address1__c != null ? shop.Address1__c : ''}<br>
                                        纬度: ${shop.Shop_Center_Location__Latitude__s.toFixed(6)}<br>
                                        经度: ${shop.Shop_Center_Location__Longitude__s.toFixed(6)}</p>
                                        <button class="action-button" onclick="handleUpdateStore(\'${shop.Id}\')">
                                            Update Store
                                        </button>
                                    </div>
                                </div>
                            `;
                            infoWindow.close();
                            infoWindow.setContent(content);
                            infoWindow.open(marker.map, marker);
                        });
                        markers.push(marker);
                    });
                }
            );

        }

        function clearMarkers() {
            markers.forEach(marker => {
                google.maps.event.clearInstanceListeners(marker);
                marker.map = null; // 从地图移除
            });
            markers = []; // 清空数组
        }

        // 点击地图，弹出信息
        function showInfoWindow(marker, event, place, address) {
            storeAddress = address;
            const content = `
                <div id="content" class="custom-info-window">
                    <div id="siteNotice"></div>
                    <h1 id="firstHeading" >${place}</h1>
                    <div>
                        <p>
                        位置信息：<br>
                        地址：${address}<br>
                        纬度: ${event.latLng.lat().toFixed(6)}<br>
                        经度: ${event.latLng.lng().toFixed(6)}</p>
                        <button class="action-button" onclick="handleAddStore(${event.latLng.lat()}, ${event.latLng.lng()})">
                            New Store
                        </button>
                    </div>
                </div>
            `;

            infoWindow.setContent(content);
            infoWindow.open(map, marker);
        }

        // 通过经纬度获取地址信息
        function getAddressDetailsBylatLng(latLng){
            geocoder.geocode({ location: latLng }, (results, status) => {
                if (status === 'OK' && results) {
                    console.log(results);
                    getAddressDetails(results[0].address_components);
                }
            });
        }

        // 获取详细地址信息
        function getAddressDetails(address_components){
            addressDetails = { country: '', province: '', city: '', street: '' };
            address_components.forEach(function(component) {
                if (component.types.includes('country')) addressDetails.country = component.long_name;
                if (component.types.includes('administrative_area_level_1')) addressDetails.province = component.long_name;
                if (component.types.includes('locality') || component.types.includes('sublocality')) addressDetails.city = component.long_name;
                if (component.types.includes('route')) addressDetails.street = component.long_name;
            });
            console.log('鼠标点击的地址详情:', addressDetails);
        }

        // 新建门店
        function handleAddStore(lat, lng){
            console.log('wwww--lat--', lat);  // 地点名称
            console.log('wwww--lng--', lng);  // 地点名称
            console.log('wwww--address--', storeAddress);  // 地点名称
            console.log('wwww--addressDetails--', addressDetails);  // 地点名称详情
             // 当需要触发LWC方法时，发送消息
            parent.postMessage(
                { 
                    action: 'newStore',
                    lat: lat,
                    lng: lng,
                    storeAddress: storeAddress,
                    addressDetails: addressDetails,
                }, 
                '*'
            );
        }

        // 修改门店
        function handleUpdateStore(shopId){
            console.log('wwww--shopIdat--', shopId);  // 门店Id
             // 当需要触发LWC方法时，发送消息
            parent.postMessage(
                { 
                    action: 'updateStore',
                    shopId: shopId,
                }, 
                '*'
            );
        }

        // 更新标记位置
        function updateMarker(lat, lng) {
            if (marker) marker.setMap(null); // 清除旧标记
            marker = new google.maps.Marker({
                position: { lat, lng },
                map: map
            });
        }

        // Search for location
        function searchLocation() {
            const address = document.getElementById("search-box").value;
            geocoder.geocode({ 'address': address }, function(results, status) {
                if (status === 'OK') {
                    map.setCenter(results[0].geometry.location);
                    marker.setPosition(results[0].geometry.location);
                } else {
                    alert("Geocode was not successful for the following reason: " + status);
                }
            });
        }

        // 导航方法
        function getDirections() {
            directionsRenderer.setMap(null); // 清除旧路线

            const start = document.getElementById("start-location").value;
            const end = document.getElementById("end-location").value;

            const directionsService = new google.maps.DirectionsService();

            const request = {
                origin: start,
                destination: end,
                travelMode: google.maps.TravelMode.DRIVING
            };

            directionsService.route(request, function(response, status) {
                if (status === google.maps.DirectionsStatus.OK) {
                    directionsRenderer.setDirections(response);
                    directionsRenderer.setMap(map);
                } else {
                    alert("Directions request failed due to " + status);
                }
            });
        }

        // 导航开始结束地址互换
        function transfer(){
            const input_start = document.getElementById('start-location');
            const input_end = document.getElementById('end-location');

            const start = document.getElementById("start-location").value;
            const end = document.getElementById("end-location").value;

            input_start.value = end;
            input_end.value = start;
        }

        // 监听 LWC 发送的消息
        window.addEventListener('message', function(event) {
            // 验证消息来源（替换为你的 Salesforce 域名）
            console.log('wwwww---' + event.origin);
            // if (event.origin !== 'https://your-domain.my.salesforce.com') return;
            
            // 解析消息内容
            const message = event.data;
            if (message.action === 'triggerVFMethod') {
                handleMessageFromLWC(message.data);
            }
        });

        // 定义 VF 页面方法
        function handleMessageFromLWC(data) {
            console.log('收到 LWC 数据:', data);
            geocoder.geocode({ 'address': data.address }, function(results, status) {
                if (status === 'OK') {
                    map.setCenter(results[0].geometry.location);
                    if (marker) marker.setMap(null); // 清除旧标记
                    console.log(results[0]);
                    console.log(results[0].geometry.location.lat());
                    console.log(results[0].geometry.location.lng());
                    showShopInfo(results[0].geometry.location.lat(), results[0].geometry.location.lng(), 10);
                } else {
                    alert("Geocode was not successful for the following reason: " + status);
                }
            });
            
        }
    </script>

    <!-- Search Input -->
    <div>
        <div style="float:left" >
            <input class="input" style="width:400px" id="search-input" type="text" placeholder="Enter address or location"/>
        </div>
        
        <div style="float:right"  class="custom-div">
            <input class="input"  style="width:400px" id="start-location" type="text" placeholder="Enter address or start-location"/>
            <div style="display:inline">
                <svg xmlns="http://www.w3.org/2000/svg" 
                    height="30" 
                    width="40" 
                    viewBox="0 0 520 520" 
                    fill="#469efb"
                    onclick="transfer()"
                >
                    <path d="M309 24a14 14 0 0 0-20 0l-20 18a13 13 0 0 0 0 20l33 32a9 9 0 0 1-6 16H114a15 15 0 0 0-15 14v28a15 15 0 0 0 15 13h182a9 9 0 0 1 7 15l-34 33a13 13 0 0 0 0 19l20 20a14 14 0 0 0 20 0l108-105a13 13 0 0 0 0-19Zm-99 244a14 14 0 0 1 20 0l20 18a13 13 0 0 1 0 20l-34 32a9 9 0 0 0 7 16h182a15 15 0 0 1 15 14v27a15 15 0 0 1-15 14H224a9 9 0 0 0-7 15l34 33a13 13 0 0 1 0 20l-20 19a14 14 0 0 1-20 0L104 392a13 13 0 0 1 0-20Z"/>
                </svg>
            </div>
            <input class="input" style="width:400px" id="end-location" type="text" placeholder="Enter address or end-location"/>
            <button class="action-button" onclick="getDirections()" style="width: 100px">导航</button>
        </div>
    </div>
    <!-- <input id="search-box" type="text" placeholder="Enter address or location"/>
    <button onclick="searchLocation()">Search</button> -->
    <div id="map" style="height: 95vh; width: 100%;"></div>

    <!-- 引入 Google Maps API -->
    <script src="https://maps.googleapis.com/maps/api/js?key={!$Label.GoogleMapKey}&libraries=marker,places,geometry&callback=initPosition"></script>
</html>
</apex:page>