<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Product_Dimension_With_Stand</fullName>
    <active>true</active>
    <description>You must enter the number * number * number format!</description>
    <errorConditionFormula>AND(!REGEX( Product_Dimension_With_Stand__c ,&quot;^(?:[1-9]\\d*|0)(?:\\.\\d+)?\\*(?:[1-9]\\d*|0)(?:\\.\\d+)?\\*(?:(?:[1-9]\\d*|0)(?:\\.\\d+)?|[Cc])$&quot;),
!ISBLANK(Product_Dimension_With_Stand__c ) 
)</errorConditionFormula>
    <errorDisplayField>Product_Dimension_With_Stand__c</errorDisplayField>
    <errorMessage>You must enter the number * number * number format!</errorMessage>
</ValidationRule>
