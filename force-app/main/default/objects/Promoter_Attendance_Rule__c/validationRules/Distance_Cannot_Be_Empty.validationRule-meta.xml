<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Distance_Cannot_Be_Empty</fullName>
    <active>true</active>
    <errorConditionFormula>IF(AND(Need_Check_Distance__c,OR(Distance__c&lt;=0,ISBLANK(Distance__c),ISNULL(Distance__c))),true,false)</errorConditionFormula>
    <errorDisplayField>Distance__c</errorDisplayField>
    <errorMessage>Distance cannot be empty.</errorMessage>
</ValidationRule>
