<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>End_Time_Greater_Than_Start_Time</fullName>
    <active>true</active>
    <errorConditionFormula>IF( Start_time__c &gt;=  End_time__c ,true,false)</errorConditionFormula>
    <errorMessage>End time cannot be less than Start time.</errorMessage>
</ValidationRule>
