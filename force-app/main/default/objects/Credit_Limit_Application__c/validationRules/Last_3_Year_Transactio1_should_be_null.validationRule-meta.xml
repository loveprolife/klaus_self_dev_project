<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Last_3_Year_Transactio1_should_be_null</fullName>
    <active>true</active>
    <description>Last 3 Years&apos; Transaction Amount 1 (USD) should be null</description>
    <errorConditionFormula>IF(AND(Historical_Transaction_Y_N__c=FALSE,     
