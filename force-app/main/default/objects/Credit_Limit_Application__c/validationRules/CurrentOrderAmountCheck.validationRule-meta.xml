<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>CurrentOrderAmountCheck</fullName>
    <active>true</active>
    <description>请输入有效的整数值</description>
    <errorConditionFormula>IF( RecordType.Name   = &apos;NonLC&apos;, NOT(REGEX(TEXT(Estimated_Transaction_Amount_CY__c), &apos;^[0-9]+$&apos;)) || Estimated_Transaction_Amount_CY__c &lt;= 0, false)</errorConditionFormula>
    <errorDisplayField>Current_Order_Amount_USD__c</errorDisplayField>
    <errorMessage>Please enter a valid integer value.</errorMessage>
</ValidationRule>
