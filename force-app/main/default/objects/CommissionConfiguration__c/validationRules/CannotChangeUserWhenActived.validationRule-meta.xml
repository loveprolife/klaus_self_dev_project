<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>CannotChangeUserWhenActived</fullName>
    <active>true</active>
    <errorConditionFormula>IsActived__c  &amp;&amp;  ISCHANGED(ResponsiblePerson__c )</errorConditionFormula>
    <errorMessage>Can not Change Response Person When It is Actived</errorMessage>
</ValidationRule>
