<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>EndDateMustGreaterStartDate</fullName>
    <active>true</active>
    <errorConditionFormula>!ISNULL(EndDate__c) &amp;&amp; EndDate__c &lt;  StartDate__c</errorConditionFormula>
    <errorMessage>End Date Must be later than Start Date</errorMessage>
</ValidationRule>
