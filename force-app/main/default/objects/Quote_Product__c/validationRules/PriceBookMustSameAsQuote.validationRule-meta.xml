<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>PriceBookMustSameAsQuote</fullName>
    <active>true</active>
    <errorConditionFormula>Pricebook_Entry__r.Price_Book__c &lt;&gt;  Quote_Name__r.Pricebook__c</errorConditionFormula>
    <errorMessage>The quote product is no longer in the customer&apos;s price book.</errorMessage>
</ValidationRule>
