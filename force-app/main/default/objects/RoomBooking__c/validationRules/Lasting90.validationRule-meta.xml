<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Lasting90</fullName>
    <active>true</active>
    <errorConditionFormula>(EndTime__c  -  StartTime__c)*24&gt; 1.5</errorConditionFormula>
    <errorMessage>Meeting could not  last  greater  than 1.5 hour</errorMessage>
</ValidationRule>
