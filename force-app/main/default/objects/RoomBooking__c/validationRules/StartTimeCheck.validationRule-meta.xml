<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>StartTimeCheck</fullName>
    <active>true</active>
    <errorConditionFormula>StartTime__c &gt; EndTime__c</errorConditionFormula>
    <errorMessage>StartTime Must less than Endtime</errorMessage>
</ValidationRule>
