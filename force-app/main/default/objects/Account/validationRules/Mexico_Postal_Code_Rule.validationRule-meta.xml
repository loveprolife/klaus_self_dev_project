<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Mexico_Postal_Code_Rule</fullName>
    <active>true</active>
    <description>墨西哥邮编规范校验</description>
    <errorConditionFormula>AND( ISPICKVAL( Guarantor_Country_Code__c , &apos;MX&apos;) ,
   NOT(REGEX(Postal_Code__c, &quot;[0-9]{5}&quot;))
)</errorConditionFormula>
    <errorDisplayField>Postal_Code__c</errorDisplayField>
    <errorMessage>The postal code must be 5 digits long and must not contain spaces.</errorMessage>
</ValidationRule>
