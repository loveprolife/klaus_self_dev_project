<aura:component implements="flexipage:availableForAllPageTypes,force:hasRecordId,force:lightningQuickActionWithoutHeader,lightning:actionOverride" access="global">
    <aura:attribute name="recordId" type="Id" />
	<aura:html tag="style">
        .slds-modal__container{
            width: 50%;
            max-width: 50%;
        }
    </aura:html>
    <c:sampleDisplayPONewLwc recordId="{!v.recordId}" onrefreshView="{c.refreshView}" oncloseModal="{!c.closeModal}"/>
</aura:component>