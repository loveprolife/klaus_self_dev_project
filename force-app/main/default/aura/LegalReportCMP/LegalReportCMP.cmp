<aura:component implements="flexipage:availableForRecordHome,force:hasRecordId,force:lightningQuickActionWithoutHeader,lightning:actionOverride,force:appHostable" access="global" >
	
	<aura:html tag="style">
        .slds-modal__container{
            width: 34%;
            max-width:34%;
        }
    </aura:html>
	<c:legalReport recordId="{!v.recordId}" onrefreshview="{c.refreshView}" oncloseModal="{!c.closeModal}"/>
</aura:component>