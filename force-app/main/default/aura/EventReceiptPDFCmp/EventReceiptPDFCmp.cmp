		<div style="position: absolute;top:0;right:-60px;" onclick="{!c.close}" id="closeFrame">
			<lightning:buttonIcon iconName="utility:close" variant="border-inverse" title="close"
				alternativeText="Close modal" />
		</div>
	</aura:if>
