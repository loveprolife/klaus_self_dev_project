<aura:component implements="flexipage:availableForAllPageTypes,force:hasRecordId,force:lightningQuickActionWithoutHeader,lightning:actionOverride" access="global" 
    controller="NewAccountPageController">

    <!-- <aura:html tag="style">
        .slds-modal__container{
            width: 45%;
            max-width:50%;
        }
    </aura:html> -->
    
	<!-- 主记录ID -->
    <aura:attribute name="recordTypeId" type="Id" />
    <aura:attribute name="isNew" type="Boolean" />
    <aura:attribute name="isProfileName" type="Boolean" />
    <aura:attribute name="recordId" type="Id" />
    <aura:handler name="init" value="{!this}" action="{!c.initCMP}" />
    <aura:if isTrue="{!v.isProfileName}">
        <c:newAccountPageLwc recordTypeId="{!v.recordTypeId}" recordId="{!v.recordId}" isNew="{!v.isNew}" onrefreshView="{c.refreshView}" oncloseModal="{!c.closeModal}"/>
    </aura:if>
    <aura:if isTrue="{!!v.isProfileName}">
        <c:customerDupCheck recordTypeId="{!v.recordTypeId}" onrefreshView="{c.refreshView}" oncloseModal="{!c.closeModal}"/>
    </aura:if>
   
</aura:component>