<aura:component>
	<aura:attribute name="selectedRecord" type="CommonLookUpController.SearchResultWrapper" />
    <aura:attribute name="selectedRecordList" type="List" />
	<aura:attribute name="iconName" type="string"/>
	<aura:registerEvent name="CommonRecordSelectedEvt" type="c:CommonRecordSelectedEvt"/>
	<li role="presentation">
        <span class="slds-lookup__item-action slds-media slds-media--center" role="option">
        	<span class="slds-media__figure">
                <span class="slds-icon_container" title="Description of icon when needed">
                    <!-- {!v.selectedRecord.objName} :  -->
                </span>
            </span>
            <div class="slds-media__body">
                <div class="slds-lookup__result-text" onclick="{!c.selectRecord}">{!v.selectedRecord.objValue}
                </div>
            </div>
        </span>
    </li>
</aura:component>