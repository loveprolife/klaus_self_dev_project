<aura:component implements="flexipage:availableForRecordHome,force:hasRecordId,force:lightningQuickActionWithoutHeader,lightning:actionOverride,force:appHostable,flexipage:availableForAllPageTypes" 
                access="global">
    <aura:attribute name="recordId" type="Id" />
	<aura:html tag="style">
        .slds-modal__container{
            width: 100%;
            max-width:90%;
        }
    </aura:html>
    <c:researchReportLwc recordId="{!v.recordId}" onrefreshview="{c.refreshView}" onclosemodal="{!c.closeModal}"/>
</aura:component>