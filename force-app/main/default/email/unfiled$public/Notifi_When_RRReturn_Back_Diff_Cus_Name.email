<messaging:emailTemplate subject="Update Customer Name Notification" recipientType="User" relatedToType="Account">
<messaging:plainTextEmailBody >
Dear User,
    &nbsp;&nbsp;&nbsp;Name for Customer(SAP CODE: {!relatedTo.SAP_Customer_Code__c}) Should be Changed to "{!relatedTo.Name}"  in SAP System.
    &nbsp;&nbsp;&nbsp;Please Take Action in time.
  

Thanks.




</messaging:plainTextEmailBody>
</messaging:emailTemplate>