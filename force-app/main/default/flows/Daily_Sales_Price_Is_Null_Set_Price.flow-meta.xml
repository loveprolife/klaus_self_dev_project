<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>59.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <description>导入是避免数据处理太多，cpu限制</description>
    <environments>Default</environments>
    <formulas>
        <name>price</name>
        <dataType>Currency</dataType>
        <expression>{!$Record.TotalPrice__c} / {!$Record.Number__c}</expression>
        <scale>2</scale>
    </formulas>
    <interviewLabel>Daily Sales Price Is Null Set Price {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Daily Sales Price Is Null Set Price</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>FREE_FORM_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <name>Set_Price</name>
        <label>Set Price</label>
        <locationX>777</locationX>
        <locationY>384</locationY>
        <inputAssignments>
            <field>Price__c</field>
            <value>
                <elementReference>price</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>650</locationX>
        <locationY>48</locationY>
        <connector>
            <targetReference>Set_Price</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Price__c</field>
            <operator>IsNull</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <object>Retail_Number__c</object>
        <recordTriggerType>Create</recordTriggerType>
        <triggerType>RecordBeforeSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
