<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>58.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <description>培训任务修改门店同步修改 Training Personnel中的门店</description>
    <environments>Default</environments>
    <interviewLabel>Training Personnel Update Stroe {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Training Personnel Update Store</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>FREE_FORM_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <name>Update_Store</name>
        <label>Update Store</label>
        <locationX>810</locationX>
        <locationY>397</locationY>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Training_Task__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </filters>
        <inputAssignments>
            <field>Store__c</field>
            <value>
                <elementReference>$Record.Store__c</elementReference>
            </value>
        </inputAssignments>
        <object>Training_Personnel__c</object>
    </recordUpdates>
    <start>
        <locationX>650</locationX>
        <locationY>48</locationY>
        <connector>
            <targetReference>Update_Store</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Store__c</field>
            <operator>IsChanged</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <filters>
            <field>Training_Type__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>巡店培训</stringValue>
            </value>
        </filters>
        <object>Training_Task__c</object>
        <recordTriggerType>Update</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
