            <value>
                <elementReference>$Record.Rating__c</elementReference>
            </value>
        </inputAssignments>
        <object>Training_Task_User__c</object>
    </recordUpdates>
    <start>
        <locationX>624</locationX>
        <locationY>17</locationY>
        <connector>
            <targetReference>Set_Training_Task_User_Rating</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Rating__c</field>
            <operator>IsChanged</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
