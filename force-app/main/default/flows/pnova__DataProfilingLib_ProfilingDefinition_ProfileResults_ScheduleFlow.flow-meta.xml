                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <label>Yes</label>
        </rules>
    </decisions>
    <description>... this flow enables Cuneiform Administrators to schedule profiling for a given Profiling Definition -- and automate the capturing of profiling details on a regularly recurring schedule that is declaratively configured.</description>
    <environments>Default</environments>
    <formulas>
        <description>.. we use this variable to dynamically resolve the application name and correctly identify emails sent to the customer .</description>
        <name>ApplicationName</name>
        <dataType>String</dataType>
        <expression>&apos;Cuneiform for &apos; + IF( CONTAINS({!recGet_ProfilingDefinition.RecordType.DeveloperName},&apos;CRM&apos;),&apos;CRM&apos;, IF( CONTAINS({!recGet_ProfilingDefinition.RecordType.DeveloperName},&apos;Data Cloud&apos;),&apos;Data Cloud&apos;, &apos;Salesforce&apos;))+&apos;:&apos;</expression>
    </formulas>
    <formulas>
        <description>... this formula will build the URL to the profiling definition record for use in the email body.</description>
        <name>ProfilingDefinitionLink</name>
        <dataType>String</dataType>
        <expression>LEFT({!$Api.Enterprise_Server_URL_510}, FIND( &apos;/services&apos;, {!$Api.Enterprise_Server_URL_510}))&amp;{!recGet_ProfilingDefinition.Id}</expression>
    </formulas>
    <interviewLabel>Cuneiform: Profiling Definition: Profiling Results: Schedule Flow {!$Flow.CurrentDateTime}</interviewLabel>
    <isTemplate>true</isTemplate>
    <label>Cuneiform: Profiling Definition: Profile Results: Schedule Flow</label>
    <processMetadataValues>
        <name>BuilderType</name>
