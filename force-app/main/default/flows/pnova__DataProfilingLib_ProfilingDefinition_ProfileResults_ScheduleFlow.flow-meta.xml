    <constants>
        <description>... represents the Profiling Definition Key identifier of the Profiling Definition to schedule. Please note that any Profiling Definition must have an active status of true to profile.</description>
        <name>ProfilingDefinitionKey</name>
        <dataType>String</dataType>
    </constants>
    <constants>
        <description>... represents the username of the user that is profiling on this schedule.  The user specified must have sufficient rights to manually profile a given profiling definition.</description>
        <name>ProfilingUsername</name>
        <dataType>String</dataType>
    </constants>
    <decisions>
        <description>... evaluate if a specified profiling definition was found.  We filter out in-active profiling definitions -- as Cuneiform does not support profiling of inactive profiling definitions.</description>
        <name>dec_Was_ProfilingDefinition_Found</name>
        <label>Was a Profiling Definition Found?</label>
        <locationX>248</locationX>
        <locationY>576</locationY>
        <defaultConnector>
            <targetReference>Send_Email_No_Definition_Found</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Was Not Verified</defaultConnectorLabel>
        <rules>
            <name>Was_Verified</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>recGet_ProfilingDefinition.pnova__Prop_IsActive__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Create_Profile_Request_Action</targetReference>
            </connector>
            <label>Was Verified</label>
        </rules>
    </decisions>
    <decisions>
        <description>... evaluates if all required Constant properties have been defined successfully.</description>
        <name>dec_Were_Constants_Defined</name>
        <label>Were Constants Defined?</label>
        <locationX>479</locationX>
        <locationY>252</locationY>
        <defaultConnectorLabel>Not Defined</defaultConnectorLabel>
        <rules>
            <name>dec_Were_Constants_Defined_true</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>ProfilingDefinitionKey</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue></stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>ProfilingUsername</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue></stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>recGet_ProfilingDefinition</targetReference>
            </connector>
            <label>Are Defined</label>
        </rules>
    </decisions>
    <decisions>
        <name>Was_the_request_created_successfully</name>
