<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>62.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <decisions>
        <description>主户上的Credit_Management__c值为空时执行</description>
        <name>Decision</name>
        <label>Decision</label>
        <locationX>994</locationX>
        <locationY>443</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Credit_Management_is_null</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Parent_Customer.Credit_Management__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Parent_Customer</targetReference>
            </connector>
            <label>Credit Management is null</label>
        </rules>
    </decisions>
    <description>当主户上的Credit_Management__c为空时，分户Credit_Management__c值赋值给主户上</description>
