            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>Get_Parent_Customer.Id</elementReference>
            </value>
        </filters>
        <inputAssignments>
            <field>Credit_Management__c</field>
            <value>
                <elementReference>$Record.Credit_Management__c</elementReference>
